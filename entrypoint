#!/bin/sh
set -eu

[ "$#" -eq 0 ] || exec "$@"

own() { [ "$(stat -c '%u' "$1" 2>/dev/null)" = "$(id -u "$2")" ] || chown -R "$2:$2" "$1"; }
mdo() { env LD_PRELOAD="$RUBY_JEMALLOC" "$@"; }
wait_url() { until wget -qO- "$1" >/dev/null 2>&1; do sleep 0.5; done; }

mkdir -p "$PGDATA";     own "$PGDATA" postgres
mkdir -p "$DB_HOST";    chown postgres:postgres "$DB_HOST"; chmod 3775 "$DB_HOST"
mkdir -p "$REDIS_DATA"; own "$REDIS_DATA" redis

[ -s "$PGDATA/PG_VERSION" ] || \
  su-exec postgres initdb -D "$PGDATA" --encoding=UTF8 --locale=C

su-exec postgres postgres \
  -D "$PGDATA" -k "$DB_HOST" -p "$DB_PORT" \
  -c listen_addresses=127.0.0.1 \
  -c shared_buffers="$POSTGRES_SHARED_BUFFERS" \
  -c maintenance_work_mem="$POSTGRES_MAINTENANCE_WORK_MEM" \
  -c work_mem="$POSTGRES_WORK_MEM" \
  -c max_connections="$POSTGRES_MAX_CONNECTIONS" \
  -c wal_buffers="$POSTGRES_WAL_BUFFERS" \
  -c huge_pages=off \
  -c wal_level=minimal \
  -c max_wal_senders=0 \
  -c full_page_writes=off \
  -c synchronous_commit=off \
  -c autovacuum_max_workers=1 \
  -c bgwriter_lru_maxpages=10 \
  -c checkpoint_completion_target=0.9 \
  -c max_wal_size=256MB \
  -c idle_in_transaction_session_timeout=30000 \
  -c random_page_cost=1.1 &
postgres_pid="$!"

until su-exec postgres pg_isready -q -h "$DB_HOST" -p "$DB_PORT" -t 1 2>/dev/null; do
  sleep 0.2
done

su-exec postgres psql -v ON_ERROR_STOP=1 \
  -h "$DB_HOST" -p "$DB_PORT" \
  --set=app_user="$DB_USER" \
  --set=app_pass="$DB_PASS" \
  --set=app_db="$DB_NAME" <<'SQL'
SELECT format('CREATE ROLE %I LOGIN', :'app_user')
  WHERE NOT EXISTS (SELECT 1 FROM pg_roles WHERE rolname = :'app_user') \gexec
SELECT format('ALTER ROLE %I WITH PASSWORD %L', :'app_user', :'app_pass')
  WHERE :'app_pass' <> '' \gexec
SELECT format('CREATE DATABASE %I OWNER %I TEMPLATE template0 ENCODING %L',
              :'app_db', :'app_user', 'UTF8')
  WHERE NOT EXISTS (SELECT 1 FROM pg_database WHERE datname = :'app_db') \gexec
SQL

su-exec redis redis-server \
  --bind "$REDIS_HOST" --port "$REDIS_PORT" \
  --dir "$REDIS_DATA" &
redis_pid="$!"

until redis-cli -h "$REDIS_HOST" -p "$REDIS_PORT" ping >/dev/null 2>&1; do
  sleep 0.2
done

cd /opt/mastodon

mdo bundle exec rails db:migrate

mdo bundle exec puma -C config/puma.rb &
web_pid="$!"
wait_url http://127.0.0.1:3000/health

PORT=4000 node ./streaming/index.js &
streaming_pid="$!"
wait_url http://127.0.0.1:4000/api/v1/streaming/health

mdo bundle exec sidekiq &
sidekiq_pid="$!"

caddy run --config /etc/caddy/Caddyfile &
caddy_pid="$!"

shutdown() {
  trap - TERM INT
  kill "$caddy_pid" "$sidekiq_pid" "$streaming_pid" "$web_pid" "$redis_pid" "$postgres_pid" 2>/dev/null || true
  wait "$caddy_pid" "$sidekiq_pid" "$streaming_pid" "$web_pid" "$redis_pid" "$postgres_pid" 2>/dev/null || true
}
trap shutdown TERM INT

while :; do
  for pid in "$postgres_pid" "$redis_pid" "$web_pid" "$streaming_pid" "$sidekiq_pid" "$caddy_pid"; do
    kill -0 "$pid" 2>/dev/null || { shutdown; exit 1; }
  done
  sleep 5
done
